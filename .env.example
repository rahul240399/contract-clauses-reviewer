# Copy to .env and adjust. The reviewer talks to any OpenAI-compatible endpoint:
# a local Ollama server (default), vLLM, LM Studio, llama.cpp, or a hosted
# open-model API. No paid service is required.

# --- Reasoning model (OpenAI-compatible endpoint) ---
# Ollama's default. For vLLM/LM Studio/llama.cpp, point at their /v1 base URL.
LLM_BASE_URL=http://localhost:11434/v1
# Model name as the server knows it (e.g. an Ollama tag). Use qwen2.5:3b on
# low-RAM machines.
LLM_MODEL=qwen2.5:7b
# Most local servers ignore the key but require it to be non-empty.
LLM_API_KEY=not-needed
# Per-request timeout in seconds.
LLM_TIMEOUT_S=120

# --- Pipeline tuning ---
# Token budget for the assess "think" (reasoning) step.
CONTRACT_REVIEW_MAX_REASONING_TOKENS=1024
# How many times verify may bounce a failing assessment back to assess.
CONTRACT_REVIEW_MAX_ASSESS_ATTEMPTS=2
# Cap on concurrent per-rule assess calls.
CONTRACT_REVIEW_ASSESS_CONCURRENCY=4
